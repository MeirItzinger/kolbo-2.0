# ─── Server ───────────────────────────────────────────
PORT=4000
NODE_ENV=development
CLIENT_URL=http://localhost:5173
# Production: must match the exact browser origin you use (scheme + host + port).
# If you use both apex and www, list the other here (comma-separated):
# CORS_EXTRA_ORIGINS=https://www.kolbo.tv,https://kolbo.tv

# ─── Database (Neon PostgreSQL) ───────────────────────
DATABASE_URL=postgresql://user:password@ep-xxxxx.us-east-2.aws.neon.tech/kolbo?sslmode=require
DIRECT_URL=postgresql://user:password@ep-xxxxx.us-east-2.aws.neon.tech/kolbo?sslmode=require

# ─── Auth / JWT ───────────────────────────────────────
JWT_ACCESS_SECRET=your-access-secret-min-32-chars-long
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars-long
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# ─── Email (Resend) ──────────────────────────────────
EMAIL_FROM=noreply@kolbo.tv
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Stripe ───────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Mux ──────────────────────────────────────────────
MUX_TOKEN_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
MUX_TOKEN_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MUX_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
MUX_SIGNING_KEY_PRIVATE=LS0tLS1CRUdJ...base64-encoded-RSA-private-key
MUX_SIGNING_KEY_ID=xxxxxxxxxxxxxxxx

# ─── Vercel Blob (image uploads) ───────────────────────
# Recommended: a Public Blob store connected to the project (channel/hero images need public URLs).
# Vercel injects BLOB_READ_WRITE_TOKEN when the store is connected — redeploy after connecting.
# Local dev: copy BLOB_READ_WRITE_TOKEN from Vercel → Storage → your store → Settings / quickstart.
# If unset locally, images go to apps/api/uploads (ephemeral on Vercel serverless).
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#
# Leave BLOB_ACCESS unset for a Public store (default). Only if the store is Private:
# BLOB_ACCESS=private

# ─── Ads (optional) ───────────────────────────────────
# Local testing: allow preroll from DRAFT campaigns before admin approval.
# Production: omit or set false (only APPROVED / ACTIVE campaigns run ads).
# AD_ALLOW_DRAFT_PREROLL=true
